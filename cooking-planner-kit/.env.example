# Server-side only. Never expose to the browser.

# Generation provider. The repo's active generator uses Gemini; the Anthropic
# slot stays here for the optional swap-back.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Supabase (Phase 3 — saved plans, history). Run supabase/migrations/0001_init.sql
# in your Supabase project before first use.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Hard monthly spend ceiling for the generation endpoint (in cents).
GENERATION_MONTHLY_CAP_CENTS=50000
